# MindMitra server configuration
# Copy this file to ".env" and fill in your key. The app runs WITHOUT a key too —
# it falls back to a deterministic offline analyzer so the demo never breaks.

# Your Anthropic API key (https://console.anthropic.com). Leave blank to use mock mode.
ANTHROPIC_API_KEY=

# Model to use. Defaults to claude-sonnet-4-6 (fast + empathetic for live chat).
# claude-opus-4-8 is the most capable if you want maximum quality.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ElevenLabs ElevenAgents voice conversations. Add the API key in Railway.
# ELEVENLABS_AGENT_ID is optional; if blank, the server auto-picks your first agent.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Port the API server listens on (the client dev server proxies /api here).
PORT=8787
